# PrayEasy Environment Variables
# Copy this file to .env.local and fill in your values

# OpenAI API Key (Required for Pastor Hope AI)
OPENAI_API_KEY="your-openai-api-key-here"

# Database (PostgreSQL via Supabase)
DATABASE_URL="postgresql://username:password@host:5432/prayeasy"

# Supabase (Required for data storage)
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key-here"

# Resend API (Optional - for welcome emails)
RESEND_API_KEY="re_your-resend-api-key-here"

# Next.js (Optional)
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here"
